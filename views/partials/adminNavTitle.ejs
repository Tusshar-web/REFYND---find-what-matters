<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
        font-family: 'Inter', sans-serif;
        display: flex;
        flex-direction: column;
        height: 100vh;
        background: #f4f6fb;
        color: #1e293b;
        overflow: hidden; /* body stays locked — sidebar stays fixed */
    }

    .top-header {
        height: 64px;
        background: #fff;
        border-bottom: 1px solid #e8edf5;
        display: flex;
        align-items: center;
        padding: 0 24px;
        gap: 16px;
        z-index: 100;
        flex-shrink: 0;
    }

    .top-header .brand {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        min-width: 200px;
    }

    .brand-icon {
        width: 34px;
        height: 34px;
        background: linear-gradient(135deg, #10b981, #059669); /* Green for admin */
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 14px;
        font-weight: 800;
        letter-spacing: -1px;
    }

    .brand-name {
        font-size: 18px;
        font-weight: 700;
        color: #1e293b;
        letter-spacing: -0.3px;
    }

    .admin-badge {
        background: #10b981;
        color: white;
        font-size: 10px;
        font-weight: 700;
        padding: 2px 6px;
        border-radius: 4px;
        margin-left: 8px;
        letter-spacing: 0.5px;
    }

    .header-right {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .user-pill {
        display: flex;
        align-items: center;
        gap: 9px;
        padding: 5px 12px 5px 5px;
        border-radius: 50px;
        background: #f8fafc;
        border: 1.5px solid #e2e8f0;
        cursor: pointer;
        transition: border-color 0.2s;
    }

    .user-pill:hover { border-color: #10b981; }

    .user-avatar {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
        font-size: 11px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .user-name {
        font-size: 13px;
        font-weight: 600;
        color: #1e293b;
    }

    .user-pill i { font-size: 10px; color: #94a3b8; }

    /* ── BODY LAYOUT ── */
    .app-body {
        display: flex;
        flex: 1;
        overflow-y: auto;   /* ← THIS is the scroll container */
        overflow-x: hidden;
        min-height: 0;
    }

    /* ── SIDEBAR ── */
    .sidebar {
        width: 220px;
        background: #fff;
        border-right: 1px solid #e8edf5;
        padding: 20px 12px;
        display: flex;
        flex-direction: column;
        gap: 24px;
        flex-shrink: 0;
        transition: width 0.3s ease;
        position: sticky;
        top: 0;
        height: 100vh;
        overflow-y: auto;
    }

    .section-title {
        font-size: 10.5px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #94a3b8;
        padding: 0 8px;
        margin-bottom: 4px;
    }

    .nav-group {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .nav-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 10px;
        border-radius: 9px;
        text-decoration: none;
        font-size: 13.5px;
        font-weight: 500;
        color: #64748b;
        transition: all 0.18s ease;
        cursor: pointer;
        border: none;
        background: none;
        width: 100%;
        text-align: left;
    }

    .nav-item i {
        width: 18px;
        text-align: center;
        font-size: 14px;
        flex-shrink: 0;
    }

    .nav-item:hover { background: #f1f5f9; color: #1e293b; }

    .nav-item.active {
        background: #ecfdf5;
        color: #10b981;
        font-weight: 600;
    }

    .nav-item.active i { color: #10b981; }

    .nav-item.logout { color: #ef4444; margin-top: auto; }
    .nav-item.logout:hover { background: #fef2f2; }

    .main-content {
        overflow-y: auto;
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

    .main-content::-webkit-scrollbar { display: none; }
</style>

<!-- TOP HEADER -->
<div class="top-header">
    <a href="/admin" class="brand">
        <div class="brand-icon">R</div>
        <span class="brand-name">REFYND</span>
        <span class="admin-badge">ADMIN</span>
    </a>

    <div class="header-right">
        <a href="/profile" style="text-decoration: none;">
            <div class="user-pill">
                <div class="user-avatar" id="navUserAvatar">A</div>
                <span class="user-name" id="navUserName">Admin</span>
                <i class="fa-solid fa-chevron-down"></i>
            </div>
        </a>
    </div>
</div>

<!-- APP BODY: sidebar + page content slot -->
<div class="app-body">
    <div class="sidebar" id="sidebar">
        <div class="nav-group">
            <div class="section-title">Admin Controls</div>
            <a href="/admin" class="nav-item" data-path="/admin">
                <i class="fa-solid fa-chart-pie"></i>
                <span class="nav-label">Dashboard</span>
            </a>
            <!-- Future admin tools can go here (e.g., Manage Users, Settings) -->
        </div>

        <div class="nav-group">
            <div class="section-title">Navigation</div>
            <a href="/items-page" class="nav-item" data-path="/items-page">
                <i class="fa-solid fa-house"></i>
                <span class="nav-label">Back to App</span>
            </a>
        </div>

        <div class="nav-group" style="margin-top: auto;">
            <a href="/logout" class="nav-item logout">
                <i class="fa-solid fa-right-from-bracket"></i>
                <span class="nav-label">Logout</span>
            </a>
        </div>
    </div>
    <!-- Page content injected here by each .ejs view -->
    <script>
        (function() {
            const path = window.location.pathname;
            document.querySelectorAll('.nav-item[data-path]').forEach(el => {
                if (el.dataset.path === path) {
                    el.classList.add('active');
                }
            });

            // Populate top header user pill globally
            const user = JSON.parse(localStorage.getItem('user') || '{}');
            if (user.full_name) {
                const navUserName = document.getElementById('navUserName');
                const navUserAvatar = document.getElementById('navUserAvatar');
                if (navUserName) navUserName.textContent = user.full_name;
                if (navUserAvatar) {
                    if (user.profile_image) {
                        navUserAvatar.innerHTML = `<img src="/uploads/${user.profile_image}" style="width:100%;height:100%;border-radius:50%;object-fit:cover;">`;
                        navUserAvatar.style.background = 'transparent';
                    } else {
                        navUserAvatar.textContent = user.full_name.split(' ').map(n => n[0]).join('').substring(0, 2).toUpperCase();
                    }
                }
            }

            // Handle Logout
            document.querySelectorAll('.logout').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.preventDefault();
                    localStorage.removeItem('token');
                    localStorage.removeItem('user');
                    window.location.href = '/login';
                });
            });
        })();
    </script>
