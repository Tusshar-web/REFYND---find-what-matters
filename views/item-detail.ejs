<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      body {
        font-family: 'Inter', sans-serif;
        background: #f4f6fb;
        min-height: 100vh;
        padding: 40px 16px;
        color: #1e293b;
      }

      .container {
        max-width: 800px;
        margin: 0 auto;
      }

      a.back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 24px;
        padding: 10px 18px;
        text-decoration: none;
        color: #4f46e5;
        background-color: #ede9fe;
        font-size: 14px;
        font-weight: 600;
        border-radius: 50px;
        transition: all 0.2s ease;
      }

      a.back-link:hover {
        background-color: #ddd6fe;
        color: #4338ca;
        transform: translateY(-1px);
      }

      .detail-card {
        background: #ffffff;
        border-radius: 20px;
        box-shadow: 0 10px 40px -10px rgba(0,0,0,0.08);
        overflow: hidden;
        display: flex;
        flex-direction: column;
      }

      @media (min-width: 768px) {
        .detail-card {
          flex-direction: row;
        }
      }

      .detail-image-wrapper {
        flex: 1;
        background: #f8fafc;
        display: flex;
        align-items: center;
        justify-content: center;
        border-right: 1px solid #e2e8f0;
        position: relative;
        min-height: 300px;
      }

      .detail-image-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        position: absolute;
        top: 0;
        left: 0;
      }
      
      .no-image-placeholder {
        color: #94a3b8;
        font-size: 48px;
      }

      .detail-content {
        flex: 1;
        padding: 40px;
        display: flex;
        flex-direction: column;
      }

      .status-badges {
        display: flex;
        gap: 8px;
        margin-bottom: 16px;
      }

      .badge {
        font-size: 11px;
        font-weight: 700;
        padding: 6px 12px;
        border-radius: 50px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      .badge-type { background: #f1f5f9; color: #475569; }
      .badge-status-lost { background: #fef2f2; color: #ef4444; border: 1px solid #fecaca; }
      .badge-status-found { background: #f0fdf4; color: #22c55e; border: 1px solid #bbf7d0; }
      .badge-status-resolved { background: #f8fafc; color: #94a3b8; border: 1px solid #e2e8f0; }

      .item-title {
        font-size: 28px;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 8px;
        line-height: 1.2;
      }

      .item-category {
        color: #64748b;
        font-size: 15px;
        font-weight: 500;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 6px;
      }

      .item-description {
        font-size: 15.5px;
        color: #475569;
        line-height: 1.7;
        margin-bottom: 32px;
        background: #f8fafc;
        padding: 20px;
        border-radius: 12px;
        border-left: 4px solid #4f46e5;
      }

      .claim-btn {
        margin-top: auto;
        padding: 14px 24px;
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        color: #fff;
        border: none;
        border-radius: 12px;
        font-size: 16px;
        font-family: inherit;
        font-weight: 600;
        cursor: pointer;
        box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3);
        transition: opacity 0.2s, transform 0.1s, box-shadow 0.2s;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        width: 100%;
      }

      .claim-btn:hover {
        opacity: 0.95;
        box-shadow: 0 6px 16px rgba(79, 70, 229, 0.4);
        transform: translateY(-1px);
      }

      .claim-btn:active {
        transform: translateY(0);
      }

      .resolved-msg {
        margin-top: auto;
        padding: 16px;
        background: #f1f5f9;
        color: #64748b;
        border-radius: 12px;
        text-align: center;
        font-weight: 600;
        font-size: 14px;
      }

      .error {
        color: #ef4444;
        background: #fef2f2;
        border: 1px solid #fecaca;
        padding: 16px;
        border-radius: 12px;
        font-size: 15px;
        font-weight: 500;
        text-align: center;
      }

      /* MODAL */
      .modal {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(4px);
        z-index: 1000;
        align-items: center;
        justify-content: center;
      }

      .modal.open { display: flex; }

      .modal-content {
        background: #ffffff;
        width: 90%;
        max-width: 480px;
        padding: 40px;
        border-radius: 20px;
        box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.2);
        position: relative;
        animation: modalSlideUp 0.3s ease-out;
      }
      
      @keyframes modalSlideUp {
          from { opacity: 0; transform: translateY(20px) scale(0.95); }
          to { opacity: 1; transform: translateY(0) scale(1); }
      }

      .modal-content h2 {
        font-size: 24px;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 24px;
      }

      .close {
        position: absolute;
        top: 20px;
        right: 24px;
        cursor: pointer;
        font-size: 24px;
        color: #94a3b8;
        transition: color 0.2s;
        line-height: 1;
      }

      .close:hover { color: #0f172a; }

      .form-group { margin-bottom: 20px; }

      .form-group label {
        display: block;
        margin-bottom: 8px;
        font-size: 13px;
        font-weight: 600;
        color: #475569;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      .form-group textarea {
        width: 100%;
        padding: 14px;
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        font-size: 15px;
        font-family: inherit;
        color: #1e293b;
        background: #f8fafc;
        resize: vertical;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
      }

      .form-group textarea:focus {
        border-color: #4f46e5;
        box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
        background: #fff;
      }

      .submit-btn {
        width: 100%;
        padding: 14px;
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        color: #fff;
        border: none;
        border-radius: 12px;
        font-size: 15.5px;
        font-family: inherit;
        font-weight: 600;
        cursor: pointer;
        box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3);
        transition: opacity 0.2s, transform 0.1s;
        margin-top: 8px;
      }

      .submit-btn:hover { opacity: 0.95; transform: translateY(-1px); }
      .submit-btn:active { transform: translateY(0); }

      .contact-admin-btn {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        width: 100%;
        padding: 14px;
        background: #f1f5f9;
        color: #475569;
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        font-size: 15px;
        font-family: inherit;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        transition: all 0.2s;
        margin-top: 12px;
      }

      .contact-admin-btn:hover { background: #e2e8f0; color: #1e293b; }
    </style>
  </head>

  <body>
    <a href="/items-page" class="back-link">&larr; Back to Items</a>

    <div id="itemDetailContainer">Loading item details...</div>

    <!-- CLAIM MODAL -->
    <div id="claimModal" class="modal">
      <div class="modal-content">
        <span class="close">&times;</span>
        <h2>Claim Item</h2>
        <form id="claimForm">
          <div class="form-group">
            <label for="proof">Please Provide Proof of Ownership</label>
            <textarea
              id="proof"
              rows="4"
              placeholder="Describe where/when you lost it, or any details that prove this is yours..."
              required
            ></textarea>
          </div>
          <div class="form-group">
            <label for="identifyingFeature">Unique Identifying Feature</label>
            <textarea
              id="identifyingFeature"
              rows="3"
              placeholder="Example: scratch mark, college ID, custom sticker..."
              required
            ></textarea>
          </div>
          <button type="submit" class="submit-btn">Submit Claim</button>
          <a href="/chat/<%= itemId %>" class="contact-admin-btn">Contact Admin</a>
        </form>
      </div>
    </div>

    <script>
      const itemId = "<%= itemId %>";

      async function fetchItemDetail() {
        try {
          const response = await fetch("/items/" + itemId);
          const item = await response.json();
          const container = document.getElementById("itemDetailContainer");

          if (response.ok && item) {
            let statusClass = 'resolved';
            if (item.status && item.status.toLowerCase() === 'lost') statusClass = 'lost';
            if (item.status && item.status.toLowerCase() === 'found') statusClass = 'found';

            const imageHtml = item.image_url 
                ? `<img src="/uploads/${item.image_url}" alt="${item.item_name}">` 
                : `<div class="no-image-placeholder"><i class="fa-solid fa-image"></i></div>`;

            container.innerHTML = `
                <div class="detail-card">
                    <div class="detail-image-wrapper">
                        ${imageHtml}
                    </div>
                    <div class="detail-content">
                        <div class="status-badges">
                            <span class="badge badge-status-${statusClass}">${escapeHTML(item.status)}</span>
                            <span class="badge badge-type">${escapeHTML(item.item_type)}</span>
                        </div>
                        <h2 class="item-title">${escapeHTML(item.item_name)}</h2>
                        <div class="item-category">
                            <i class="fa-solid fa-layer-group"></i> ${escapeHTML(item.category)}
                        </div>
                        <div class="item-description">
                            ${escapeHTML(item.description)}
                        </div>
                        
                        ${
                            item.status !== "resolved" && item.status !== "closed" && item.status !== "claimed"
                            ? `<button id="claimBtn" class="claim-btn"><i class="fa-solid fa-hand-sparkles"></i> Claim This Item</button>`
                            : `<div class="resolved-msg">This item is no longer available to claim.</div>`
                        }
                    </div>
                </div>
            `;

            const claimBtn = document.getElementById("claimBtn");
            if (claimBtn) {
              claimBtn.addEventListener("click", () => {
                document.getElementById("claimModal").classList.add("open");
              });
            }
          } else {
            container.innerHTML = `<div class="error">${item.message || "Failed to load item details."}</div>`;
          }
        } catch (error) {
          document.getElementById("itemDetailContainer").innerHTML =
            `<p class="error">Error: ${error.message}</p>`;
        }
      }

      // CLOSE MODAL
      document.querySelector(".close").addEventListener("click", () => {
        document.getElementById("claimModal").classList.remove("open");
      });

      // CLOSE WHEN CLICK OUTSIDE
      window.onclick = function (event) {
        const modal = document.getElementById("claimModal");
        if (event.target == modal) {
          modal.classList.remove("open");
        }
      };

      // SUBMIT CLAIM
      document
        .getElementById("claimForm")
        .addEventListener("submit", async (e) => {
          e.preventDefault();

          const proof_message = document.getElementById("proof").value;
          const identifying_feature =
            document.getElementById("identifyingFeature").value;

          try {
            const token = localStorage.getItem("token");
            const response = await fetch("/claim", {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
                Authorization: `Bearer ${token}`,
              },
              body: JSON.stringify({
                item_id: itemId,
                proof_description: proof_message,
                identifying_feature,
              }),
            });

            const data = await response.json();

            if (response.ok) {
              alert("Claim submitted successfully!");
              document.getElementById("claimForm").reset();
              document.getElementById("claimModal").classList.remove("open");
            } else {
              alert(data.message || "Failed to submit claim");
            }
          } catch (error) {
            alert("Error: " + error.message);
          }
        });

      function escapeHTML(str) {
        if (!str) return '';
        return str.toString().replace(/[&<>'"]/g, 
            tag => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[tag] || tag)
        );
      }

      fetchItemDetail();
    </script>
  </body>
</html>
